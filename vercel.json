{
    "experimentalServices": {
        "frontend": {
            "root": "frontend",
            "routePrefix": "/",
            "framework": "vite"
        },
        "backend": {
            "root": "backend",
            "routePrefix": "/_/backend",
            "framework":"express"
        }
    },
    "rewrites": [
      {
        "source": "/api/:path*",
        "destination": "/backend/src/index.ts"
      }
    ]
  }
  