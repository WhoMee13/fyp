// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum AuthProvider {
  LOCAL
  GOOGLE
  BOTH
}

enum PropertyType {
  Residential
  Agricultural
  Commercial
}

enum PropertyPurpose {
  Sale
  Rent
}

enum PropertyStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ListingStatus {
  ACTIVE
  SOLD_OUT
  RENTED_OUT
}

enum SizeUnit {
  sq_ft
  sq_m
  ropani
  acre
}

model User {
  id           String       @id @default(uuid())
  name         String
  email        String       @unique
  phone        String?
  password     String?
  googleId     String?      @unique @map("google_id")
  authProvider AuthProvider @default(LOCAL) @map("auth_provider")
  role         UserRole     @default(CUSTOMER)
  status       UserStatus   @default(ACTIVE)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  properties      Property[]
  contactRequests ContactRequest[] @relation("SenderContacts")
  vendorProfile   VendorProfile?
  customerBookings Booking[]       @relation("CustomerBookings")
  vendorBookings   Booking[]       @relation("VendorBookings")

  @@map("users")
}

model Property {
  id            String          @id @default(uuid())
  title         String
  description   String          @db.Text
  propertyType  PropertyType    @map("property_type")
  purpose       PropertyPurpose
  price         Float
  landSize      Float           @map("land_size")
  sizeUnit      SizeUnit        @map("size_unit")
  status        PropertyStatus  @default(PENDING)
  listingStatus ListingStatus   @default(ACTIVE) @map("listing_status")
  isActive      Boolean         @default(true) @map("is_active")
  ownerId       String          @map("owner_id")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  // Residential specific fields
  bedrooms      Int?            @map("bedrooms")
  bathrooms     Int?            @map("bathrooms")
  bhkType       String?         @map("bhk_type") // 1BHK, 2BHK, 3BHK, etc.
  floors        Int?            @map("floors")
  totalFloors   Int?            @map("total_floors")
  parkingSpaces Int?            @map("parking_spaces")
  
  // Commercial specific fields
  officeSpace   Float?          @map("office_space") // in sq ft
  hasParking    Boolean?        @default(false) @map("has_parking")
  amenities     String?         @db.Text @map("amenities")
  
  // Agricultural specific fields
  soilType      String?         @map("soil_type")
  waterAccess   Boolean?        @default(false) @map("water_access")
  cropType      String?         @map("crop_type")

  owner     User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  images    PropertyImage[]
  location  Location?
  contactRequests ContactRequest[]
  bookings  Booking[]

  @@map("properties")
}

model PropertyImage {
  id         String   @id @default(uuid())
  propertyId String   @map("property_id")
  imageUrl   String   @map("image_url")
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_images")
}

model Location {
  id        String   @id @default(uuid())
  propertyId String  @unique @map("property_id")
  address   String
  city      String
  state     String?
  country   String   @default("Nepal")
  latitude  Float?
  longitude Float?

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("locations")
}

model ContactRequest {
  id        String   @id @default(uuid())
  propertyId String  @map("property_id")
  senderId  String   @map("sender_id")
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  sender   User     @relation("SenderContacts", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("contact_requests")
}

enum VendorStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingType {
  RENTAL
  PURCHASE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED_BY_VENDOR
  CANCELLED_BY_CUSTOMER
  COMPLETED
}

model VendorProfile {
  id               String        @id @default(uuid())
  userId           String        @unique @map("user_id")
  citizenshipId    String        @map("citizenship_id")
  frontImagePath   String        @map("front_image_path")
  backImagePath    String        @map("back_image_path")
  status           VendorStatus  @default(PENDING)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("vendor_profiles")
}

model Booking {
  id          String         @id @default(uuid())
  propertyId  String         @map("property_id")
  customerId  String         @map("customer_id")
  vendorId    String         @map("vendor_id")
  type        BookingType
  startDate   DateTime       @map("start_date")
  endDate     DateTime?      @map("end_date") // null for purchase bookings
  totalPrice  Float?         @map("total_price")
  status      BookingStatus  @default(PENDING)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  property    Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  customer    User           @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Cascade)
  vendor      User           @relation("VendorBookings", fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("bookings")
}

model SiteSetting {
  id            String   @id @default(uuid())
  logo          String?
  appName       String   @default("PropertyRental")
  footerText    String?  @db.Text
  copyrightText String?
  contactEmail  String?
  contactPhone  String?
  address       String?
  updatedAt     DateTime @updatedAt

  @@map("site_settings")
}

